# Omaya hospital-portal frontend — environment template.
# Copy to `.env` (gitignored). All vars are build-time (Vite `VITE_` prefix);
# they're inlined at build, so set them in the deploy environment too.

# Backend portal API base URL. Dev → the local FastAPI server.
# Prod example: https://backend-api.omayacare.com
VITE_API_BASE_URL=http://localhost:8000

# Call-service base URL — used only by the unified docs page (src/Docs.tsx) to
# load the call-service OpenAPI. Optional: when unset, the docs page falls back
# to the bundled snapshot in public/openapi/.
# Prod example: https://call-service.omayacare.com
VITE_CALL_SERVICE_URL=
