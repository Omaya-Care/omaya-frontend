# Omaya hospital-portal frontend — environment template.
# Copy to `.env` (gitignored). All vars are build-time (Vite `VITE_` prefix);
# they're inlined at build, so set them in the deploy environment too.

# Backend portal API base URL. Dev → the local FastAPI server.
# Prod example: https://backend-api.omayacare.com
VITE_API_BASE_URL=http://localhost:8000

# NOTE: API-docs access is gated SERVER-SIDE by the backend `docs_access`
# table (a signed-in clinician whose email is allowlisted). The docs page
# fetches BOTH the portal spec (/openapi.json) and the call-service spec
# (/call-service.openapi.json, a team-gated backend proxy) with the Bearer
# JWT, and shows a "no access" state on a 403. The call-service's own
# /openapi.json is closed off (internal-secret only), so there's no
# VITE_CALL_SERVICE_URL — its spec is reached only through the backend.
